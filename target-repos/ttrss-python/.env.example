# Copy to .env and fill in real values — NEVER commit .env

# Flask
SECRET_KEY=change-me-to-a-long-random-string

# PostgreSQL (ADR-0003)
DATABASE_URL=postgresql://ttrss:ttrss@localhost:5432/ttrss

# Redis (ADR-0007)
REDIS_URL=redis://localhost:6379/0

# Fernet key for feed credential encryption (ADR-0009)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FEED_CRYPT_KEY=

# Session cookie lifetime in seconds (default 86400 = 1 day)
# SESSION_COOKIE_LIFETIME=86400

# Test database (used by docker-compose.test.yml + tests/conftest.py)
# TEST_DATABASE_URL=postgresql://ttrss_test:ttrss_test@localhost:5433/ttrss_test
# TEST_REDIS_URL=redis://localhost:6380/1
