# New: no PHP equivalent — Postgres service environment variables template.
# Phase 6 B4: separate from app env_file so DB credentials are isolated.
#
# Usage: cp .env.db.example .env.db
#        Edit .env.db with real values (never commit .env.db)

POSTGRES_DB=ttrss
POSTGRES_USER=ttrss
POSTGRES_PASSWORD=CHANGE_ME
